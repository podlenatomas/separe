    "About": {
        "eyebrow": "About us",
        "title": "A family business in the heart of the city",
        "description": "Separé was born from a simple idea: we wanted to create a spot in the heart of Prague where we'd actually want to hang out ourselves. No stiff service, no corporate vibe — just an honest family business where you feel like a person, not a patron. We're obsessed with real craft and bold flavors. We leave the average to others — if it's on our menu, we'd stake our reputation on it.",
        "swipeHint": "Swipe to explore",
        "values": {
            "beer": {
                "title": "Craft Beer",
                "text": "A carefully curated tap list from small breweries. We rotate regularly so there's always something new to discover."
            },
            "wine": {
                "title": "Sparkling Wine & Pet-Nat",
                "text": "We go way beyond Italian Prosecco. Expect interesting bubbles and natural wines — best enjoyed when you crack open a whole bottle with friends."
            },
            "quality": {
                "title": "Quality Czech Wines",
                "text": "Local excellence from trusted winemakers, doing justice to Czech craft. Premium single-vineyard wines carefully guarded in our collection."
            },
            "games": {
                "title": "Board Games & Quizzes",
                "text": "Over 30 games to borrow for free. Regular game nights and our legendary Wednesday pub quizzes. You don't just stop by — you stay."
            }
        }
    },
