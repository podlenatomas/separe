"Reviews": {
    "eyebrow": "Reviews",
    "title": "Word in the courtyard.",
    "description": "Separé stands on simple things — good drinks, a warm atmosphere, and people who keep coming back. This is what you write about us. It makes our day.",
    "ctaPrompt": "Stopped by and had a good time? We'd love a review, it helps us grow.",
    "cta": "Leave a review on Google",
