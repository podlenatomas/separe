        "fallback": {
            "r1": {
                "name": "Martin K.",
                "text": "Úžasné místo s neopakovatelnou atmosférou. Řemeslná piva jsou skvělá, personál přátelský a ta zahrada ve dvoře — parádní únik z centra. Chodíme sem pravidelně na kvízy.",
                "date": "před 2 týdny"
            },
            "r2": {
                "name": "Tereza M.",
                "text": "Konečně bar, kde se dá normálně posedět bez hluku a fronty. Vynikající výběr vín, pet-naty fantastické. Salonek jsme využili na narozeniny a bylo to přesně, jak jsme chtěli.",
                "date": "před měsícem"
            },
            "r3": {
                "name": "Jakub P.",
                "text": "Nejlepší úkryt před světem v Praze. Přijdete na jedno pivo, odejdete po třech hodinách s novou oblíbenou deskovkou. Obsluha je milá a ví, co doporučit. Vrátím se.",
                "date": "před 3 týdny"
            }
        }
    },
