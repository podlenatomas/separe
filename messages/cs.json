    "About": {
        "eyebrow": "O nás",
        "title": "Rodinný bar uprostřed Prahy 1.",
        "description": "Separé je rodinný craft bar v Mikulandské 133/3, Praha 1. Vzniklo z jednoduché myšlenky: chtěli jsme v centru Prahy vytvořit místo, kam bychom sami rádi chodili. Žádný neosobní bar s naškrobenou obsluhou. Poctivý rodinný podnik, kde se cítíte jako člověk, ne jako host. Milujeme poctivé řemeslo a zajímavé chutě. Průměr přenecháváme jiným. Do lístku pouštíme jen to, za co dáme ruku do ohně.",
        "swipeHint": "Tahem posuňte",
        "values": {
            "beer": {
                "title": "Craft pivo z malých pivovarů.",
                "text": "Pečlivý výběr rotujícího čepu — vždy z nezávislých, malých pivovarů. Nabídku pravidelně obměňujeme, aby bylo pořád co objevovat."
            },
            "wine": {
                "title": "Šumivá vína & Pet-nat.",
                "text": "Neomezujeme se na italské Prosecco. Nabízíme pet-nat a přírodní vína — bubliny, které si nejvíc užijete, když si s přáteli otevřete rovnou celou lahev."
            },
            "quality": {
                "title": "Přívlastková česká vína.",
                "text": "Lokální kvalita od prověřených vinařů. Špičková česká přívlastková vína pečlivě střežená v naší vinotéce — kategorie, která dělá čest tuzemskému řemeslu."
            },
            "games": {
                "title": "Deskovky & Kvízy — každý den, zdarma.",
                "text": "Přes 30 her k zapůjčení zdarma — od rychlých party kousků po náročnější strategie. Pravidelné herní večery. A legendární středeční hospodské kvízy. U nás se nezastavuje jen na \u201ejedno\u201c — u nás se zůstává."
            }
        }
    },
